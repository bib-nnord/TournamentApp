generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  user_id         Int       @id @default(autoincrement())
  username        String    @unique @db.VarChar(50)
  email           String    @unique @db.VarChar(255)
  password_hash   String    @db.VarChar(255)
  display_name    String?   @db.VarChar(100)
  first_name      String?   @db.VarChar(100)
  last_name       String?   @db.VarChar(100)
  date_of_birth   DateTime? @db.Date
  bio             String?   @db.Text
  location        String?   @db.VarChar(200)
  avatar_url      String?   @db.VarChar(500)
  site_role       SiteRole  @default(user)
  email_confirmed     Boolean        @default(false)
  allow_messages_from MessagePrivacy @default(everyone)
  created_at          DateTime       @default(now()) @db.Timestamp(6)

  team_memberships TeamMember[]
  created_teams    Team[]          @relation("TeamCreator")
  sent_messages    Message[]       @relation("MessageSender")
  received_messages Message[]      @relation("MessageRecipient")
  refresh_tokens   RefreshToken[]

  created_tournaments      Tournament[]              @relation("TournamentCreator")
  tournament_entries       TournamentParticipant[]    @relation("TournamentParticipants")
  match_entries            MatchParticipant[]         @relation("MatchParticipantUser")
  sent_friend_requests     Friendship[]               @relation("FriendshipRequester")
  received_friend_requests Friendship[]               @relation("FriendshipRecipient")

  @@map("user")
}

enum MessagePrivacy {
  everyone
  friends_only
}

enum SiteRole {
  user
  organizer
  moderator
  admin
}

// ─── Refresh Tokens ─────────────────────────────────────────────────────────

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique @db.VarChar(64)
  user_id    Int
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_token")
}

// ─── Teams ──────────────────────────────────────────────────────────────────

model Team {
  team_id     Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  image_url   String?  @db.VarChar(500)
  is_open     Boolean  @default(false)
  created_by  Int
  created_at  DateTime @default(now()) @db.Timestamp(6)

  creator User         @relation("TeamCreator", fields: [created_by], references: [user_id])
  members TeamMember[]

  match_entries      MatchParticipant[]      @relation("MatchParticipantTeam")
  tournament_entries TournamentParticipant[] @relation("TournamentParticipantTeam")

  @@map("team")
}

model TeamMember {
  team_id   Int
  user_id   Int
  role      TeamRole @default(member)
  joined_at DateTime @default(now()) @db.Timestamp(6)

  team Team @relation(fields: [team_id], references: [team_id])
  user User @relation(fields: [user_id], references: [user_id])

  @@id([team_id, user_id])
  @@map("team_member")
}

enum TeamRole {
  lead
  moderator
  member
}

// ─── Messages ───────────────────────────────────────────────────────────────

model Message {
  message_id     Int             @id @default(autoincrement())
  sender_id      Int?
  recipient_id   Int?
  sender_name    String?         @db.VarChar(100)
  recipient_name String?         @db.VarChar(100)
  category       MessageCategory
  folder         MessageFolder   @default(inbox)
  subject        String          @db.VarChar(200)
  body           String          @db.Text
  is_read        Boolean         @default(false)
  reference_id   Int?
  created_at     DateTime        @default(now()) @db.Timestamp(6)

  sender    User? @relation("MessageSender", fields: [sender_id], references: [user_id], onDelete: SetNull)
  recipient User? @relation("MessageRecipient", fields: [recipient_id], references: [user_id], onDelete: SetNull)

  @@map("message")
}

enum MessageCategory {
  users
  teams
  tournaments
  website
}

enum MessageFolder {
  inbox
  sent
}

// ─── Friendships ───────────────────────────────────────────────────────────

model Friendship {
  friendship_id  Int              @id @default(autoincrement())
  requester_id   Int
  recipient_id   Int
  status         FriendshipStatus @default(pending)
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  updated_at     DateTime         @updatedAt @db.Timestamp(6)

  requester User @relation("FriendshipRequester", fields: [requester_id], references: [user_id], onDelete: Cascade)
  recipient User @relation("FriendshipRecipient", fields: [recipient_id], references: [user_id], onDelete: Cascade)

  @@unique([requester_id, recipient_id])
  @@index([recipient_id])
  @@map("friendship")
}

enum FriendshipStatus {
  pending
  accepted
  blocked
}

// ─── Tournaments ────────────────────────────────────────────────────────────

model Tournament {
  tournament_id  Int               @id @default(autoincrement())
  name           String            @db.VarChar(200)
  game           String            @db.VarChar(100)
  description    String?           @db.Text
  format         TournamentFormat
  status         TournamentStatus  @default(draft)
  is_private     Boolean           @default(false)
  max_participants Int?
  start_date     DateTime?         @db.Timestamp(6)
  bracket_data   Json?
  created_by     Int
  created_at     DateTime          @default(now()) @db.Timestamp(6)
  updated_at     DateTime          @updatedAt @db.Timestamp(6)

  creator      User                    @relation("TournamentCreator", fields: [created_by], references: [user_id])
  participants TournamentParticipant[]
  matches      Match[]

  @@map("tournament")
}

model TournamentParticipant {
  tournament_id    Int
  seed             Int
  user_id          Int?
  team_id          Int?
  participant_type ParticipantType @default(guest)
  guest_name       String?         @db.VarChar(100)
  display_name     String          @db.VarChar(100)
  members_snapshot Json?           // snapshot of team members at tournament time
  confirmed        Boolean         @default(false)
  declined         Boolean         @default(false)
  joined_at        DateTime        @default(now()) @db.Timestamp(6)

  tournament Tournament @relation(fields: [tournament_id], references: [tournament_id], onDelete: Cascade)
  user       User?      @relation("TournamentParticipants", fields: [user_id], references: [user_id])
  team       Team?      @relation("TournamentParticipantTeam", fields: [team_id], references: [team_id])

  @@id([tournament_id, seed])
  @@map("tournament_participant")
}

enum ParticipantType {
  account
  guest
  team
}

enum TournamentFormat {
  single_elimination
  double_elimination
  round_robin
  double_round_robin
  combination
  swiss
}

enum TournamentStatus {
  draft
  registration
  active
  completed
  cancelled
}

// ─── Matches ────────────────────────────────────────────────────────────────

model Match {
  match_id       Int          @id @default(autoincrement())
  tournament_id  Int?
  round          String?      @db.VarChar(100)
  position       Int?
  status         MatchStatus  @default(scheduled)
  score_a        Int?
  score_b        Int?
  scheduled_at   DateTime?    @db.Timestamp(6)
  played_at      DateTime?    @db.Timestamp(6)
  notes          String?      @db.Text
  created_at     DateTime     @default(now()) @db.Timestamp(6)

  tournament   Tournament?        @relation(fields: [tournament_id], references: [tournament_id], onDelete: Cascade)
  participants MatchParticipant[]

  @@map("match")
}

model MatchParticipant {
  id            Int       @id @default(autoincrement())
  match_id      Int
  side          MatchSide
  user_id       Int?
  team_id       Int?
  team_name     String?   @db.VarChar(100)
  display_name  String    @db.VarChar(100)

  match Match @relation(fields: [match_id], references: [match_id], onDelete: Cascade)
  user  User? @relation("MatchParticipantUser", fields: [user_id], references: [user_id])
  team  Team? @relation("MatchParticipantTeam", fields: [team_id], references: [team_id])

  @@index([match_id, side])
  @@map("match_participant")
}

enum MatchSide {
  a
  b
}

enum MatchStatus {
  scheduled
  in_progress
  completed
  tie
  cancelled
}
